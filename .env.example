# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Clerk (https://dashboard.clerk.com → API Keys) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/workflow
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/workflow

# --- PostgreSQL / Neon (https://neon.tech) ---
# Example local: postgresql://USER:PASSWORD@localhost:5432/nextflow?schema=public
DATABASE_URL=
# --- Trigger.dev (https://cloud.trigger.dev → Project → API Keys & Project ref) ---
TRIGGER_SECRET_KEY=
TRIGGER_API_URL=https://api.trigger.dev
TRIGGER_PROJECT_REF=

# --- Google Gemini (https://aistudio.google.com/apikey) — also add same key in Trigger.dev project env ---
GEMINI_API_KEY=

# --- Transloadit (https://transloadit.com → Account → Credentials & Template ID) ---
TRANSLOADIT_AUTH_KEY=
TRANSLOADIT_AUTH_SECRET=
TRANSLOADIT_TEMPLATE_ID=

# --- Optional: only if not using Trigger ffmpeg extension defaults ---
# FFMPEG_PATH=
# FFPROBE_PATH=

# --- Cron Scheduler (independent worker) ---
# Base URL used by the scheduler to call POST /api/workflows/[id]/runs
SCHEDULER_BASE_URL=http://localhost:3000
# Poll interval in ms (default 60000)
SCHEDULER_POLL_MS=60000
# Parse and match cron in UTC by default (set false to use local server time)
SCHEDULER_USE_UTC=true
# Clerk session token used as __session cookie when calling the runs API.
# You can set one global token OR a JSON map per userId.
SCHEDULER_SESSION_TOKEN=
# Example: {"user_123":"sess_xxx","user_456":"sess_yyy"}
SCHEDULER_USER_SESSION_TOKENS=
