# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Clerk (https://dashboard.clerk.com → API Keys) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/workflow
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/workflow

# --- PostgreSQL / Neon (https://neon.tech) ---
# Example local: postgresql://USER:PASSWORD@localhost:5432/nextflow?schema=public
DATABASE_URL=
# --- Trigger.dev (https://cloud.trigger.dev → Project → API Keys & Project ref) ---
TRIGGER_SECRET_KEY=
TRIGGER_API_URL=https://api.trigger.dev
TRIGGER_PROJECT_REF=

# --- Google Gemini (https://aistudio.google.com/apikey) — also add same key in Trigger.dev project env ---
GEMINI_API_KEY=

# --- Transloadit (https://transloadit.com → Account → Credentials & Template ID) ---
TRANSLOADIT_AUTH_KEY=
TRANSLOADIT_AUTH_SECRET=
TRANSLOADIT_TEMPLATE_ID=

# --- Optional: only if not using Trigger ffmpeg extension defaults ---
# FFMPEG_PATH=
# FFPROBE_PATH=
